{
  "manifest_version": 3,
  "name": "ZH Downloader",
  "version": "2.0.0",
  "description": "One-click download for videos, audio, and any file. ZH Motions internal tool.",
  "author": "ZH Motions",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZH Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "webRequest",
    "storage",
    "downloads",
    "activeTab",
    "tabs",
    "scripting",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:9613/*"],
  "minimum_chrome_version": "100"
}
