<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="$(var.AppName)"
           Language="1033"
           Version="$(var.AppVersion)"
           Manufacturer="$(var.AppAuthor)"
           UpgradeCode="A1B2C3D4-1234-5678-9ABC-ZH00MOTIONS03">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine"
             Description="$(var.AppName) — Universal Download Manager"
             Comments="Built by $(var.AppAuthor) · zhmotions.com"
             Manufacturer="$(var.AppAuthor)" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of $(var.AppName) is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="AppIcon.ico" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON"  Value="AppIcon.ico" />
    <Property Id="ARPHELPLINK"     Value="https://zhmotions.com" />
    <Property Id="ARPURLINFOABOUT" Value="https://zhmotions.com" />
    <Property Id="ARPNOREPAIR"     Value="yes" Secure="yes" />
    <Property Id="ARPNOMODIFY"     Value="yes" Secure="yes" />
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="$(var.AppName)">
          <Component Id="MainExecutable" Guid="B1C2D3E4-AAAA-BBBB-CCCC-ZH00EXE00001" Win64="yes">
            <File Id="AppExe" Source="$(var.ExePath)" KeyPath="yes" Checksum="yes" />
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="$(var.AppName)">
          <Component Id="StartMenuShortcut" Guid="C2D3E4F5-AAAA-BBBB-CCCC-ZH00SRT00001">
            <Shortcut Id="StartMenuShortcutLink"
                      Name="$(var.AppName)"
                      Description="Universal Download Manager by ZH Motions"
                      Target="[INSTALLFOLDER]ZHDownloader.exe"
                      WorkingDirectory="INSTALLFOLDER"
                      Icon="AppIcon.ico" IconIndex="0" />
            <Shortcut Id="UninstallShortcut"
                      Name="Uninstall $(var.AppName)"
                      Target="[SystemFolder]msiexec.exe"
                      Arguments="/x [ProductCode]" />
            <RemoveFolder Id="RemoveAppMenuFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\ZHMotions\ZHDownloader"
                           Name="installed" Type="integer" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop">
        <Component Id="DesktopShortcut" Guid="D3E4F5A6-AAAA-BBBB-CCCC-ZH00DSK00001">
          <Shortcut Id="DesktopShortcutLink"
                    Name="$(var.AppName)"
                    Description="Universal Download Manager by ZH Motions"
                    Target="[INSTALLFOLDER]ZHDownloader.exe"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="AppIcon.ico" IconIndex="0" />
          <RegistryValue Root="HKCU" Key="Software\ZHMotions\ZHDownloader"
                         Name="desktop" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </Directory>
    <Feature Id="MainFeature" Title="$(var.AppName)" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>
    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="WixShellExecTarget" Value="[#AppExe]" />
    <CustomAction Id="LaunchApp" BinaryKey="WixCA" DllEntry="WixShellExec" Impersonate="yes" />
    <InstallExecuteSequence>
      <Custom Action="LaunchApp" After="InstallFinalize">NOT Installed</Custom>
    </InstallExecuteSequence>
  </Product>
</Wix>
